#include <Wire.h>
#include <MPU9250_asukiaaa.h>
#include <MadgwickAHRS.h>
#include <WiFi.h>    // 🌐 Wi-Fi library
#include <WiFiUdp.h> // 🌐 UDP Network library

MPU9250_asukiaaa sensor;
Madgwick filter;
WiFiUDP udp;

// ==========================================
// HOTSPOT CONFIGURATION (AP MODE)
// ==========================================
const char* ssid     = "NEURAL_RIFLE_HUD"; // Name of your ESP32 Hotspot
const char* password = "Password123";      // Hotspot password (Must be at least 8 characters)

// Broadcasting to .255 automatically sends data to any PC connected to the hotspot
const char* broadcastIP = "192.168.4.255"; 
const int udpPort       = 4210;            // Matches port 4210 inside your Python HUD script

// Buttons
const int FIRE_BTN = 25;
const int CAL_BTN  = 26;

// Bias values (Preserved exactly)
float gxBias = 1.06;
float gyBias = 0.30;
float gzBias = 0.24;

// Center reference
float centerPitch = 0;
float centerYaw = 0;
bool centered = false;
bool lastCal = false;

void setup() {
  Serial.begin(115200);
  Wire.begin();

  pinMode(FIRE_BTN, INPUT_PULLUP);
  pinMode(CAL_BTN, INPUT_PULLUP);

  sensor.setWire(&Wire);
  sensor.beginAccel();
  sensor.beginGyro();

  filter.begin(100);

  // 🌐 Launching standalone ESP32 Hotspot
  Serial.print("Configuring Access Point: ");
  Serial.println(ssid);
  WiFi.softAP(ssid, password);
  
  Serial.println("Hotspot Activated Successfully!");
  Serial.print("ESP32 Hotspot IP Address: ");
  Serial.println(WiFi.softAPIP()); // Usually defaults to 192.168.4.1

  udp.begin(udpPort);
  Serial.print("UDP Broadcast engine active on Port: ");
  Serial.println(udpPort);
}

void loop() {
  sensor.accelUpdate();
  sensor.gyroUpdate();

  // Your MPU-9250 axes remapping and bias math (Unchanged)
  float gx = sensor.gyroY() - gxBias;   
  float gy = sensor.gyroX() - gyBias;   
  float gz = sensor.gyroZ() - gzBias;

  float ax = sensor.accelY();           
  float ay = sensor.accelX();           
  float az = sensor.accelZ();

  filter.updateIMU(gx, gy, gz, ax, ay, az);

  float pitch = filter.getPitch();
  float yaw   = filter.getYaw();

  bool fire = !digitalRead(FIRE_BTN);
  bool cal  = !digitalRead(CAL_BTN);

  if (cal && !lastCal) {
    centerPitch = pitch;
    centerYaw = yaw;
    centered = true;
  }
  lastCal = cal;

  if (centered) {
    pitch -= centerPitch;
    yaw   -= centerYaw;
  }

  if (abs(pitch) < 0.2) pitch = 0;
  if (abs(yaw) < 0.2) yaw = 0;

  // Format data string to match what your Python app expects
  String telemetry = String(pitch, 2) + "," + String(yaw, 2) + "," + String(fire) + "," + String(cal);

  // Print to local USB Serial for easy Arduino IDE monitoring
  Serial.println(telemetry);

  // Send data over Wi-Fi Hotspot directly to your PC via UDP broadcast
  udp.beginPacket(broadcastIP, udpPort);
  udp.print(telemetry);
  udp.endPacket();

  delay(10); // 100Hz refresh rate
}
