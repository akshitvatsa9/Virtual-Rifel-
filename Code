def redraw():
    canvas.delete("dot")
    canvas.delete("live_elements")

    ix, iy = int(x), int(y)

    if len(live_path) > 1:
        flat_points = [int(coord) for pt in live_path for coord in pt]
        canvas.create_line(flat_points, fill=ACCENT_GREEN, width=2, capstyle="round", smooth=True, tags="live_elements")

    for shot in shots:
        sx, sy = int(shot[0]), int(shot[1])
        canvas.create_oval(sx-8, sy-8, sx+8, sy+8, outline=ACCENT_RED, width=1, tags="dot")
        canvas.create_oval(sx-2, sy-2, sx+2, sy+2, fill=ACCENT_RED, outline="", tags="dot")

    if show_crosshair:
        canvas.create_line(ix-20, iy, ix-6, iy, fill=ACCENT_CYAN, width=1, tags="live_elements")
        canvas.create_line(ix+6, iy, ix+20, iy, fill=ACCENT_CYAN, width=1, tags="live_elements")
        canvas.create_line(ix, iy-20, ix, iy-6, fill=ACCENT_CYAN, width=1, tags="live_elements")
        canvas.create_line(ix, iy+6, ix, iy+20, fill=ACCENT_CYAN, width=1, tags="live_elements")

    canvas.create_oval(
        ix - DOT_RADIUS, iy - DOT_RADIUS,
        ix + DOT_RADIUS, iy + DOT_RADIUS,
        fill="#FFFF00", outline=ACCENT_CYAN, width=1,
        tags="dot"
    )

def parse_and_update_hud(line):
    global x, y, center_pitch, center_yaw, calibrated, was_firing, live_path
    
    parts = line.split(",")
    if len(parts) != 4:
        return

    pitch = float(parts[0])
    yaw = float(parts[1])
    fire = int(parts[2])
    calibrate = int(parts[3])

    if calibrate:
        center_pitch = pitch
        center_yaw = yaw
        calibrated = True
        live_path = [] 

    if not calibrated:
        return

    rel_pitch = pitch - center_pitch
    rel_yaw = yaw - center_yaw
    s = sens.get()

    x = int(WINDOW_SIZE/2 - rel_yaw * s)
    y = int(WINDOW_SIZE/2 - rel_pitch * s)

    x = max(0, min(WINDOW_SIZE, x))
    y = max(0, min(WINDOW_SIZE, y))

    if draw_live_line:
        if not live_path or live_path[-1] != (x, y):
            live_path.append((x, y))
            if len(live_path) > 150: 
                live_path.pop(0)

    if fire:
        if not was_firing:
            current_score = score(x, y)
            timestamp = datetime.now().strftime("%H:%M:%S")
            shots.append((x, y, timestamp, current_score))
            
            root.after(0, lambda s_val=current_score: score_label.config(text=f"SCORE: {s_val:02d}"))
            root.after(0, update_table)
            play_sound()
            was_firing = True  
    else:
        was_firing = False  

    root.after(0, redraw)

def read_serial():
    while is_running:
        try:
            if ser is None or not ser.is_open:
                time.sleep(0.1) # Prevents thread from spinning aggressively when disconnected
                continue

            line = ser.readline().decode('utf-8', errors='ignore').strip()
            if line:
                parse_and_update_hud(line)

        except Exception as e:
            print(f"HUD Serial Exception: {e}")
            time.sleep(0.5)

def read_wifi():
    while is_running:
        try:
            if udp_socket is None:
                time.sleep(0.1) # Fixes high CPU utilization when disconnected
                continue
            
            try:
                data, addr = udp_socket.recvfrom(1024)
                line = data.decode('utf-8', errors='ignore').strip()
                if line:
                    parse_and_update_hud(line)
            except socket.timeout:
                continue # Graceful skip on timeout ticks to keep thread responsive
            
        except Exception as e:
            print(f"HUD Wi-Fi Exception: {e}")
            time.sleep(0.5)

# Clean shutdown protocol when user closes window
def on_closing():
    global is_running, ser, udp_socket
    is_running = False
    try:
        if ser and ser.is_open:
            ser.close()
        if udp_socket:
            udp_socket.close()
    except:
        pass
    root.destroy()

root.protocol("WM_DELETE_WINDOW", on_closing)
root.mainloop()
