def compile_shot_logs():
    report = "== HUD DATA TERMINAL EXPORT ==\n"
    report += f"Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\n"
    report += f"Total recorded data packets: {len(shots)}\n"
    report += "---------------------------------------\n"
    for i, (_, _, timestamp, hit_score) in enumerate(shots[:50], 1):
        report += f"Shot #{i:02d} | Time: [{timestamp}] | Telemetry Score: {hit_score:02d} Pts\n"
    report += "---------------------------------------\n"
    report += "End of System Stream Log Transmission."
    return report

def generate_pil_image():
    card_size = 400
    img = Image.new("RGB", (card_size, card_size), BG_COLOR)
    draw = ImageDraw.Draw(img)
    
    scale = card_size / WINDOW_SIZE
    center = card_size / 2
    tgt_r = TARGET_RADIUS * scale
    
    for i in range(10):
        r = tgt_r * (10 - i) / 10
        ring_color = "#1E293B" if i % 2 == 0 else ACCENT_CYAN
        ring_width = 1 if i % 2 == 0 else 2
        draw.ellipse([center-r, center-r, center+r, center+r], outline=ring_color, width=ring_width)
        
    draw.line([center-tgt_r, center, center+tgt_r, center], fill="#1E293B", width=1)
    draw.line([center, center-tgt_r, center, center+tgt_r], fill="#1E293B", width=1)
    
    for shot in shots:
        sx, sy = shot[0] * scale, shot[1] * scale
        draw.ellipse([sx-5, sy-5, sx+5, sy+5], outline=ACCENT_RED, width=1)
        draw.ellipse([sx-1, sy-1, sx+1, sy+1], fill=ACCENT_RED)
        
    return img

