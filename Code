def connect():
    global ser, udp_socket
    try:
        # Gracefully shut down existing Wi-Fi socket if active
        if udp_socket:
            udp_socket.close()
            udp_socket = None
            
        if ser and ser.is_open:
            ser.close()
            
        ser = serial.Serial(port_var.get(), 115200, timeout=1)
        status.config(text="HUD: SERIAL ONLINE", fg=ACCENT_CYAN)
        threading.Thread(target=read_serial, daemon=True).start()
    except Exception as e:
        status.config(text="LINK ERROR", fg=ACCENT_RED)

def connect_wifi():
    global udp_socket, ser
    try:
        # Gracefully shut down existing Serial stream if active
        if ser and ser.is_open:
            ser.close()
            ser = None

        if udp_socket:
            udp_socket.close()
            
        udp_socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        # Avoid "Address already in use" system flags on restarts
        udp_socket.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        udp_socket.bind(("0.0.0.0", 4210))
        udp_socket.settimeout(1.0) # Prevents thread lockups when waiting for packets
        
        status.config(text="HUD: WIFI ONLINE", fg=ACCENT_GREEN)
        threading.Thread(target=read_wifi, daemon=True).start()
    except Exception as e:
        status.config(text="WIFI LINK ERROR", fg=ACCENT_RED)
        print(f"Network error: {e}")

